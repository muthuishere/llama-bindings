# llama-bindings — GitHub Secrets / Environment Variables
#
# Copy this file to .env for local development (never commit .env).
# All secrets listed here must be added to the repository's GitHub Secrets
# (Settings → Secrets and variables → Actions) before running the publish workflow.
#
# Required for publishing:
# ─────────────────────────────────────────────────────────────────────────────

# npm publish (publish.yml job: publish-npm)
# Create at https://www.npmjs.com/settings/<username>/tokens
NPM_TOKEN=

# Maven Central / OSSRH publish (publish.yml job: publish-java)
# Register at https://central.sonatype.com/
OSSRH_USERNAME=
OSSRH_PASSWORD=

# GPG key for Maven Central artifact signing
# Export with: gpg --export-secret-keys --armor <KEY_ID>
MAVEN_GPG_PRIVATE_KEY=
MAVEN_GPG_PASSPHRASE=

# ─────────────────────────────────────────────────────────────────────────────
# Optional:
# ─────────────────────────────────────────────────────────────────────────────

# HuggingFace access token — used by the e2e workflow to download the
# Qwen2.5-0.5B-Instruct GGUF model.  The model is publicly available so
# this token is only needed if HuggingFace rate-limits anonymous downloads.
# Create at https://huggingface.co/settings/tokens
HUGGING_FACE_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Local development overrides (not used by CI):
# ─────────────────────────────────────────────────────────────────────────────

# Path to a downloaded GGUF model for local e2e tests.
# Defaults to tests/models/qwen2.5-0.5b-instruct-q4_k_m.gguf if unset.
LLAMA_CHAT_MODEL=
LLAMA_EMBED_MODEL=
