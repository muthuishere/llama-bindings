<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
             https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>tools.muthuishere</groupId>
  <artifactId>llama-bindings-java</artifactId>
  <version>0.1.0</version>
  <packaging>jar</packaging>

  <name>llama-java</name>
  <description>Java bindings for the llama.cpp bridge library (Project Panama FFM).</description>
  <url>https://github.com/muthuishere/llama-bindings</url>

  <properties>
    <maven.compiler.source>22</maven.compiler.source>
    <maven.compiler.target>22</maven.compiler.target>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <!-- Native library build output dir (set by Taskfile before maven runs). -->
    <bridge.lib.dir>${project.basedir}/../../bridge/build</bridge.lib.dir>
    <surefire.groups></surefire.groups>
    <surefire.excludedGroups>e2e</surefire.excludedGroups>
  </properties>

  <dependencies>
    <!-- JSON serialization for request/response marshalling. -->
    <dependency>
      <groupId>com.fasterxml.jackson.core</groupId>
      <artifactId>jackson-databind</artifactId>
      <version>2.17.1</version>
    </dependency>

    <!-- SQLite for KnowledgeStore persistence. -->
    <dependency>
      <groupId>org.xerial</groupId>
      <artifactId>sqlite-jdbc</artifactId>
      <version>3.47.2.0</version>
    </dependency>

    <!-- Testing -->
    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter</artifactId>
      <version>5.10.2</version>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <!-- Compiler: enable Project Panama FFM APIs (GA in JDK 22+). -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.13.0</version>
        <configuration>
          <source>22</source>
          <target>22</target>
          <release>22</release>
        </configuration>
      </plugin>

      <!-- Surefire: run JUnit 5 tests and enable Panama FFM preview flags. -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <version>3.2.5</version>
        <configuration>
          <!-- Default: exclude e2e tests that need a real model + bridge. -->
          <groups>${surefire.groups}</groups>
          <excludedGroups>${surefire.excludedGroups}</excludedGroups>
          <argLine>
            --enable-native-access=ALL-UNNAMED
            -Djava.library.path=${bridge.lib.dir}
          </argLine>
        </configuration>
      </plugin>

      <!-- Source jar for Maven Central publishing. -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-source-plugin</artifactId>
        <version>3.3.0</version>
        <executions>
          <execution>
            <id>attach-sources</id>
            <goals>
              <goal>jar-no-fork</goal>
            </goals>
          </execution>
        </executions>
      </plugin>

      <!-- Javadoc jar for Maven Central publishing. -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-javadoc-plugin</artifactId>
        <version>3.6.3</version>
        <executions>
          <execution>
            <id>attach-javadocs</id>
            <goals>
              <goal>jar</goal>
            </goals>
          </execution>
        </executions>
        <configuration>
          <additionalOptions>
            <option>--enable-native-access=ALL-UNNAMED</option>
          </additionalOptions>
        </configuration>
      </plugin>
    </plugins>
  </build>
  <profiles>
    <!--
      E2E profile: includes @Tag("e2e") tests that require a built native
      bridge and a downloaded Qwen2.5 GGUF model.

      Activate with:
        mvn test -Pe2e -Dbridge.lib.dir=../../bridge/build \
          -DLLAMA_CHAT_MODEL=../../tests/models/qwen2.5-0.5b-instruct-q4_k_m.gguf
    -->
    <profile>
      <id>e2e</id>
      <properties>
        <surefire.groups>e2e</surefire.groups>
        <surefire.excludedGroups></surefire.excludedGroups>
      </properties>
      <build>
        <plugins>
          <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-surefire-plugin</artifactId>
            <version>3.2.5</version>
            <configuration>
              <argLine>
                --enable-native-access=ALL-UNNAMED
                -Djava.library.path=${bridge.lib.dir}
              </argLine>
              <systemPropertyVariables>
                <LLAMA_CHAT_MODEL>${LLAMA_CHAT_MODEL}</LLAMA_CHAT_MODEL>
                <LLAMA_EMBED_MODEL>${LLAMA_EMBED_MODEL}</LLAMA_EMBED_MODEL>
              </systemPropertyVariables>
            </configuration>
          </plugin>
        </plugins>
      </build>
    </profile>
  </profiles>

</project>
